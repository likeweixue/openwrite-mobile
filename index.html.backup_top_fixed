                        <option value="30" ${interval === '30' ? 'selected' : ''}>30秒</option>
                        <option value="60" ${interval === '60' ? 'selected' : ''}>1分钟</option>
                        <option value="300" ${interval === '300' ? 'selected' : ''}>5分钟</option>
                    </select>
                </div>
                <button onclick="manualBackup()" style="margin-top: 16px; padding: 12px; background: #9b784e; color: white; border: none; border-radius: 12px; width: 100%;">立即备份</button>
            </div>
        </div>
    `;
    document.getElementById('booksContainer').innerHTML = html;
    
    let checkbox = document.getElementById('autoBackupCheckbox');
    checkbox.onchange = function(e) {
        let enabled = e.target.checked;
        localStorage.setItem('auto_backup', enabled);
        document.getElementById('autoBackupStatus').innerText = enabled ? '已开启' : '已关闭';
        let intervalSetting = document.getElementById('intervalSetting');
        intervalSetting.style.opacity = enabled ? '1' : '0.5';
        document.getElementById('backupInterval').disabled = !enabled;
        if (enabled) {
            startAutoBackup();
        } else {
            stopAutoBackup();
        }
    };
}

function saveBackupInterval() {
    let interval = document.getElementById('backupInterval').value;
    localStorage.setItem('backup_interval', interval);
    stopAutoBackup();
    startAutoBackup();
}

function startAutoBackup() {
    if (backupInterval) clearInterval(backupInterval);
    let interval = parseInt(localStorage.getItem('backup_interval') || '30') * 1000;
    backupInterval = setInterval(function() {
        manualBackup();
    }, interval);
}

function stopAutoBackup() {
    if (backupInterval) {
        clearInterval(backupInterval);
        backupInterval = null;
    }
}

function manualBackup() {
    saveData();
    alert('备份完成！数据已保存到本地');
}

