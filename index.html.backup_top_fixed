function changeFontSize(delta) {
    let current = parseInt(localStorage.getItem('mobile_font_size') || '17');
    let newSize = current + delta;
    if (newSize < 12) newSize = 12;
    if (newSize > 30) newSize = 30;
    localStorage.setItem('mobile_font_size', newSize);
    document.getElementById('fontSizeDisplay').innerText = newSize + 'px';
    document.getElementById('previewText').style.fontSize = newSize + 'px';
    // 应用到编辑器
    let editor = document.getElementById('chapterContent');
    if (editor) editor.style.fontSize = newSize + 'px';
}

function changeLineHeight(delta) {
    let current = parseFloat(localStorage.getItem('mobile_line_height') || '1.7');
    let newHeight = current + delta;
    if (newHeight < 1.2) newHeight = 1.2;
    if (newHeight > 2.5) newHeight = 2.5;
    localStorage.setItem('mobile_line_height', newHeight);
    document.getElementById('lineHeightDisplay').innerText = newHeight.toFixed(1);
    document.getElementById('previewText').style.lineHeight = newHeight;
    let editor = document.getElementById('chapterContent');
    if (editor) editor.style.lineHeight = newHeight;
}

function changeFontFamily() {
    let family = document.getElementById('fontFamilySelect').value;
    localStorage.setItem('mobile_font_family', family);
    document.getElementById('previewText').style.fontFamily = family;
    let editor = document.getElementById('chapterContent');
    if (editor) editor.style.fontFamily = family;
}

