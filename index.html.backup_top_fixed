    let totalBooks = books.length;
    let todayWords = 0;
    let weekWords = 0;
    let monthWords = 0;
    let yearWords = 0;
    let writingDays = new Set();
    
    let now = new Date();
    let todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
    let weekStart = todayStart - 6 * 86400000;
    let monthStart = new Date(now.getFullYear(), now.getMonth(), 1).getTime();
    let yearStart = new Date(now.getFullYear(), 0, 1).getTime();
    
    for (let book of books) {
        for (let vol of book.volumes) {
            for (let ch of vol.chapters) {
                let words = (ch.content || '').replace(/<[^>]*>/g, '').length;
                totalWords += words;
                totalChapters++;
                
                let updateTime = new Date(ch.updatedTime);
                let timeKey = updateTime.toDateString();
                writingDays.add(timeKey);
                
                if (updateTime.getTime() >= todayStart) todayWords += words;
                if (updateTime.getTime() >= weekStart) weekWords += words;
                if (updateTime.getTime() >= monthStart) monthWords += words;
                if (updateTime.getTime() >= yearStart) yearWords += words;
            }
        }
    }
    
    return {
        totalWords: totalWords,
        totalChapters: totalChapters,
        totalBooks: totalBooks,
        totalDays: writingDays.size,
        todayWords: todayWords,
        weekWords: weekWords,
        monthWords: monthWords,
        yearWords: yearWords,
        avgWordsPerChapter: totalChapters > 0 ? Math.floor(totalWords / totalChapters) : 0,
        avgWordsPerDay: writingDays.size > 0 ? Math.floor(totalWords / writingDays.size) : 0
    };
}

// 渲染日历
function renderCalendar() {
    let year = currentStatsDate.getFullYear();
    let month = currentStatsDate.getMonth();
    let firstDay = new Date(year, month, 1);
    let startWeekday = firstDay.getDay();
    let daysInMonth = new Date(year, month + 1, 0).getDate();
    
    // 获取每天的字数
    let dailyWords = {};
    for (let book of books) {
        for (let vol of book.volumes) {
            for (let ch of vol.chapters) {
                let updateTime = new Date(ch.updatedTime);
                if (updateTime.getFullYear() === year && updateTime.getMonth() === month) {
                    let day = updateTime.getDate();
                    let words = (ch.content || '').replace(/<[^>]*>/g, '').length;
                    dailyWords[day] = (dailyWords[day] || 0) + words;
                }
            }
        }
    }
    
    let weekdays = ['日', '一', '二', '三', '四', '五', '六'];
    let html = '<div class="calendar-weekdays" style="display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; margin-bottom: 12px;">';
    for (let i = 0; i < 7; i++) {
        html += `<div style="font-size: 12px; color: #888; padding: 4px;">${weekdays[i]}</div>`;
    }
    html += '</div><div class="calendar-days" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px;">';
    
    for (let i = 0; i < startWeekday; i++) {
        html += '<div style="aspect-ratio: 1; padding: 4px;"></div>';
    }
    
    for (let d = 1; d <= daysInMonth; d++) {
        let words = dailyWords[d] || 0;
        let intensity = words > 0 ? Math.min(0.9, words / 1000) : 0;
        let isToday = (year === new Date().getFullYear() && month === new Date().getMonth() && d === new Date().getDate());
        
        html += `
            <div class="calendar-day ${words > 0 ? 'has-writing' : ''} ${isToday ? 'today' : ''}" 
                 style="aspect-ratio: 1; background: ${words > 0 ? `rgba(155, 120, 78, ${0.2 + intensity * 0.6})` : '#f8f8f8'}; border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; ${isToday ? 'border: 2px solid #9b784e;' : ''}"
                 onclick="showDayDetail(${year}, ${month + 1}, ${d})">
                <span style="font-size: 14px; font-weight: ${isToday ? '600' : '400'};">${d}</span>
                ${words > 0 ? `<span style="font-size: 9px; color: #9b784e;">${words}</span>` : ''}
            </div>
        `;
    }
    html += '</div>';
    return html;
}

function changeMonth(delta) {
    currentStatsDate.setMonth(currentStatsDate.getMonth() + delta);
    renderStatsPage();
}

function showDayDetail(year, month, day) {
    let dateStr = `${year}-${month}-${day}`;
    let content = '';
    for (let book of books) {
        for (let vol of book.volumes) {
            for (let ch of vol.chapters) {
                let updateTime = new Date(ch.updatedTime);
                if (updateTime.getFullYear() === year && updateTime.getMonth() + 1 === month && updateTime.getDate() === day) {
                    let words = (ch.content || '').replace(/<[^>]*>/g, '').length;
                    content += `<div style="padding: 8px 0; border-bottom: 1px solid #eee;">
                        <div style="font-weight: 500;">${book.title} - ${ch.title}</div>
                        <div style="font-size: 12px; color: #888;">${words} 字</div>
                    </div>`;
                }
            }
        }
    }
    if (content) {
        alert(`📅 ${year}年${month}月${day}日\n\n${content}\n共 ${content.match(/<div>/g)?.length || 0} 个章节更新`);
    } else {
        alert(`${year}年${month}月${day}日\n\n暂无写作记录`);
    }
}

