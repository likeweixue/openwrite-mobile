    let achievements = [];
    
    if (stats.totalWords >= 1000) achievements.push({ name: '初涉文坛', desc: '累计字数达到1000', icon: '🌱' });
    if (stats.totalWords >= 10000) achievements.push({ name: '小有名气', desc: '累计字数达到1万', icon: '🌟' });
    if (stats.totalWords >= 50000) achievements.push({ name: '笔耕不辍', desc: '累计字数达到5万', icon: '✍️' });
    if (stats.totalWords >= 100000) achievements.push({ name: '著作等身', desc: '累计字数达到10万', icon: '🏆' });
    if (stats.totalDays >= 7) achievements.push({ name: '七日之约', desc: '连续写作7天', icon: '📅' });
    if (stats.totalDays >= 30) achievements.push({ name: '满月之勤', desc: '写作满30天', icon: '🌙' });
    if (stats.totalBooks >= 1) achievements.push({ name: '开山之作', desc: '创建第一本书籍', icon: '📖' });
    if (stats.totalBooks >= 3) achievements.push({ name: '多产作者', desc: '拥有3本以上书籍', icon: '📚' });
    if (stats.todayWords >= 500) achievements.push({ name: '日更达人', desc: '单日码字500+', icon: '⚡' });
    if (stats.todayWords >= 2000) achievements.push({ name: '码字狂人', desc: '单日码字2000+', icon: '🔥' });
    
    if (achievements.length === 0) {
        return '<div style="text-align: center; padding: 20px; color: #888;">继续创作，解锁更多成就</div>';
    }
    
    return achievements.map(ach => `
        <div class="achievement-card" style="background: #fff; border-radius: 20px; padding: 12px 16px; display: flex; align-items: center; gap: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
            <div style="font-size: 28px;">${ach.icon}</div>
            <div>
                <div style="font-weight: 600; font-size: 14px;">${ach.name}</div>
                <div style="font-size: 10px; color: #888;">${ach.desc}</div>
            </div>
        </div>
    `).join('');
}
