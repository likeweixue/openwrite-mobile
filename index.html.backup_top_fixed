<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>写作帮手 - 移动版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: #f5f5f5;
            height: 100vh;
            overflow: hidden;
        }
        
        /* 主容器 */
        .app-container {
            display: flex;
            flex-direction: column;
            height: 100vh;
            background: #f5f5f5;
        }
        
        /* 顶部导航 - 胶囊效果 */
.top-bar {
    background: transparent;
    padding: 12px 16px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.top-bar h1 {
    display: none;
}

/* 新建书籍按钮 - 胶囊效果 */
.top-bar button {
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(20px);
    border: none;
    color: #1a1a1a;
    padding: 8px 20px;
    border-radius: 40px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.8);
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
}

.top-bar button:active {
    transform: scale(0.96);
    background: rgba(255,255,255,0.98);
}

.top-bar button::before {
    content: "+";
    font-size: 16px;
    font-weight: 600;
}
        
        /* 主内容区 */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
        }
        
        /* 书籍卡片 */
        .books-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 16px;
        }
        
        .book-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            position: relative;
        }
        
        .book-cover-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        
        .book-cover-placeholder {
            height: 180px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
        }
        
        .book-info {
            padding: 12px;
        }
        
        .book-title {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .book-stats {
            font-size: 11px;
            color: #888;
        }
        
        /* 书籍菜单按钮（三个点） */
        .book-menu-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(0,0,0,0.5);
            border: none;
            border-radius: 20px;
            width: 28px;
            height: 28px;
            font-size: 16px;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }
        
        /* 空状态 */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #999;
        }
        
        .empty-state .icon {
            font-size: 64px;
            margin-bottom: 16px;
        }
        
        /* 底部导航栏 - 胶囊等距圆角效果 */
.bottom-nav {
    display: flex;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(20px);
    border-top: none;
    padding: 6px;
    justify-content: space-around;
    border-radius: 40px;
    margin: 0 16px 16px 16px;
    gap: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.8);
}

.nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px 0;
    border-radius: 32px;
    cursor: pointer;
    flex: 1;
    text-align: center;
    transition: all 0.25s ease;
    background: transparent;
    min-height: 52px;
}

.nav-item.active {
    background: linear-gradient(135deg, #1a1a1a, #2d2d2d);
    color: #fff;
    box-shadow: 0 6px 14px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.1);
}

.nav-item:active {
    transform: scale(0.96);
}

.nav-icon {
    font-size: 20px;
    transition: transform 0.2s;
}

.nav-item.active .nav-icon {
    transform: scale(1.02);
}

.nav-label {
    font-size: 10px;
    font-weight: 500;
    transition: all 0.2s;
}

.nav-item.active .nav-label {
    font-weight: 600;
    letter-spacing: 0.3px;
}
        
        /* 新建/编辑书籍弹窗 */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #fff;
            z-index: 1000;
            overflow-y: auto;
        }
        
        .modal.open {
            display: block;
        }
        
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            border-bottom: 1px solid #eee;
            background: #fff;
            position: sticky;
            top: 0;
        }
        
        .modal-header h3 {
            font-size: 18px;
        }
        
        .modal-header button {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            padding: 0 8px;
        }
        
        .modal-content {
            padding: 20px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            font-size: 14px;
        }
        
        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 12px;
            font-size: 16px;
            font-family: inherit;
            box-sizing: border-box;
        }
        
        .form-group textarea {
            resize: vertical;
        }
        
        .cover-preview {
            width: 100%;
            height: 150px;
            background: #f5f5f5;
            border-radius: 12px;
            background-size: cover;
            background-position: center;
            border: 1px solid #ddd;
            margin-top: 8px;
        }
        
        .btn-primary {
            width: 100%;
            padding: 14px;
            background: #9b784e;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            cursor: pointer;
        }
        
        .btn-danger {
            width: 100%;
            padding: 14px;
            background: #dc3545;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 12px;
        }
        
        /* 章节列表页面 */
        .chapter-page {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #f5f5f5;
            z-index: 200;
            flex-direction: column;
        }
        
        .chapter-page.open {
            display: flex;
        }
        
        .chapter-header {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid #eee;
            background: #ffffff00; /* 章节区域的导航透明 */
            gap: 12px;
        }
        
        .back-btn {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            padding: 4px 8px;
        }
        
        .chapter-header h4 {
            flex: 1;
            font-size: 18px;
            font-weight: 600;
        }
        
        .add-chapter-btn {
            background: #9b784e;
            border: none;
            color: white;
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 13px;
            cursor: pointer;
        }
        
        .chapter-list-container {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
        }
        
        .volume-group {
            background: #fff;
            border-radius: 16px;
            margin-bottom: 16px;
            overflow: hidden;
        }
        
        .volume-title {
            padding: 14px 16px;
            background: #f8f8f8;
            font-weight: 600;
            font-size: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #eee;
            cursor: move;
        }
        
        .volume-actions {
            display: flex;
            gap: 8px;
        }
        
        .volume-actions button {
            background: none;
            border: none;
            font-size: 16px;
            cursor: pointer;
            padding: 4px 8px;
        }
        
        .chapter-item {
            padding: 14px 16px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            background: #fff;
        }
        
        .chapter-item:active {
            background: #f5f5f5;
        }
        
        .chapter-item.dragging {
            opacity: 0.3;
            background: #e0e0e0;
        }
        
        .chapter-item.drag-over {
            border-top: 2px solid #007aff;
        }
        
        .chapter-name {
            flex: 1;
            font-size: 15px;
        }
        
        .chapter-actions {
            display: flex;
            gap: 12px;
        }
        
        .chapter-actions button {
            background: none;
            border: none;
            font-size: 16px;
            cursor: pointer;
            padding: 4px;
            color: #888;
        }
        
        /* 拖拽手柄 */
        .drag-handle {
            cursor: grab;
            margin-right: 12px;
            font-size: 16px;
            color: #ccc;
        }
        
        .drag-handle:active {
            cursor: grabbing;
        }
        /* 头部按钮样式 - 胶囊效果 */
.add-volume-btn-header {
    background: #9b784e;
    border: none;
    color: white;
    padding: 8px 16px;
    border-radius: 25px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.add-volume-btn-header:active {
    transform: scale(0.96);
    background: #8a6a45;
}

.add-chapter-btn {
    background: #9b784e;
    border: none;
    color: white;
    padding: 8px 16px;
    border-radius: 25px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.add-chapter-btn:active {
    transform: scale(0.96);
    background: #8a6a45;
}
        
        /* 编辑器页面 */
        /* 编辑器页面 - 沉浸式滚动 */
.editor-page {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: #f5f5f5;
    z-index: 300;
    flex-direction: column;
}

.editor-page.open {
    display: flex;
}

/* 可滚动的内容区域（包含标题和正文） */
/* 滚动区域 - 紧贴头部下方，无多余空间 */
.editor-scroll-area {
    flex: 1;
    overflow-y: auto;
    padding: 0 20px 30px;
}
/* 编辑器头部 - 浮动层，不占用空间 */
.editor-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: transparent;  /* 完全透明 */
    gap: 12px;
    z-index: 20;
}

.editor-header h4 {
    display: none;
}

.back-btn {
    background: #ffffff;  /* 白色背景 */
    border: 1px solid rgba(0,0,0,0.1);  /* 可选：加个细边框 */
    font-size: 14px;
    cursor: pointer;
    padding: 6px 18px;
    border-radius: 30px;
    transition: all 0.2s ease;
    font-weight: 500;
    color: #333;
}

.back-btn:active {
    transform: scale(0.96);
    background: rgba(0,0,0,0.05);  /* 点击时轻微反馈 */
}

.word-count-badge {
    background: #ffffff;  /* 白色背景 */
    border: 1px solid rgba(0,0,0,0.1);  /* 可选：加个细边框 */
    font-size: 13px;
    padding: 6px 14px;
    border-radius: 30px;
    font-weight: 500;
    color: #666;
}

/* 滚动区域 - 顶部留出头部高度的空间 */
.editor-scroll-area {
    flex: 1;
    overflow-y: auto;
    padding: 70px 20px 30px;  /* 顶部留出 70px 给浮动头部 */
}

/* 章节标题输入框 - 无边框大字体，紧贴顶部 */
.chapter-title-input {
    font-size: 24px;
    font-weight: 700;
    border: none;
    padding: 0 0 8px 0;
    outline: none;
    width: 100%;
    background: transparent;
    color: #1a1a1a;
    margin: 0;
}

/* 编辑器正文 - 大行距，紧贴标题 */
.chapter-editor {
    width: 100%;
    min-height: 100vh;
    font-size: 17px;
    line-height: 1.7;
    border: none;
    outline: none;
    resize: none;
    font-family: inherit;
    background: transparent;
    color: #333;
    margin: 0;
    padding: 8px 0;
}

/* 字数统计 */
.word-count {
    text-align: right;
    font-size: 12px;
    color: #888;
    padding: 12px 0 20px;
    border-top: 1px solid rgba(0,0,0,0.05);
    margin-top: 16px;
}
        
        /* 弹窗确认 */
        .confirm-dialog {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            width: 280px;
            text-align: center;
            z-index: 2000;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            display: none;
        }
        
        .confirm-dialog.open {
            display: block;
        }
        
        .confirm-dialog p {
            margin-bottom: 20px;
        }
        
        .confirm-dialog button {
            padding: 8px 20px;
            margin: 0 8px;
            border: none;
            border-radius: 25px;
            cursor: pointer;
        }
        
        .confirm-dialog .confirm-yes {
            background: #dc3545;
            color: white;
        }
        
        .confirm-dialog .confirm-no {
            background: #eee;
        }
        
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1999;
            display: none;
        }
        
        .overlay.open {
            display: block;
        }
        /* 设置列表样式 */
.settings-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.settings-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: #fff;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.settings-item:active {
    transform: scale(0.98);
    background: #f8f8f8;
}

.settings-icon {
    font-size: 28px;
}

.settings-info {
    flex: 1;
}

.settings-name {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 4px;
}

.settings-desc {
    font-size: 12px;
    color: #888;
}

.settings-arrow {
    font-size: 24px;
    color: #ccc;
}

/* 设置卡片 */
.settings-card {
    background: #fff;
    border-radius: 24px;
    padding: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.settings-card-item {
    padding: 12px 0;
    border-bottom: 1px solid #eee;
}

.settings-card-item:last-child {
    border-bottom: none;
}

.settings-card-item label {
    font-weight: 500;
    font-size: 14px;
    color: #333;
}

/* 开关样式 */
.switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 24px;
}

.switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: 0.3s;
    border-radius: 24px;
}

.slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: 0.3s;
    border-radius: 50%;
}

input:checked + .slider {
    background-color: #9b784e;
}

input:checked + .slider:before {
    transform: translateX(26px);
}

/* 主题按钮 */
.theme-btn {
    padding: 8px 16px;
    border-radius: 25px;
    border: none;
    cursor: pointer;
    font-size: 13px;
    transition: all 0.2s;
}

.theme-btn.active {
    outline: 2px solid #007aff;
    outline-offset: 2px;
}

.theme-btn:active {
    transform: scale(0.96);
}

/* 字号调整按钮 */
.size-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: #fff;
    font-size: 18px;
    cursor: pointer;
    transition: all 0.2s;
}

.size-btn:active {
    transform: scale(0.94);
    background: #f0f0f0;
}
/* 数据统计页面样式 */
.stats-card {
    background: #fff;
    border-radius: 20px;
    padding: 16px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.stats-card-icon {
    font-size: 28px;
    margin-bottom: 8px;
}

.stats-card-number {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 4px;
}

.stats-card-label {
    font-size: 12px;
    opacity: 0.8;
}

.writing-card {
    background: #fff;
    border-radius: 20px;
    padding: 16px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.writing-label {
    font-size: 12px;
    color: #888;
    margin-bottom: 4px;
}

.writing-number {
    font-size: 24px;
    font-weight: 700;
    color: #9b784e;
}

.writing-unit {
    font-size: 11px;
    color: #888;
}

.avg-card {
    background: #fff;
    border-radius: 20px;
    padding: 16px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.avg-label {
    font-size: 12px;
    color: #888;
    margin-bottom: 8px;
}

.avg-number {
    font-size: 20px;
    font-weight: 600;
    color: #333;
}

.calendar-day {
    transition: all 0.2s;
}

.calendar-day:active {
    transform: scale(0.95);
}

.achievement-card {
    transition: all 0.2s;
}

.achievement-card:active {
    transform: scale(0.98);
}
</style>
</head>
<body>
<div class="app-container">
    <!-- 顶部栏 -->
    <div class="top-bar">
    <button id="newBookBtn">新建书籍</button>
</div>
    
    <!-- 主内容 -->
    <div class="main-content" id="mainContent">
        <div id="booksContainer"></div>
    </div>
    
    <!-- 底部导航 -->
    <div class="bottom-nav">
        <div class="nav-item active" data-page="books">
            <div class="nav-icon">📖</div>
            <div class="nav-label">书籍</div>
        </div>
        <div class="nav-item" data-page="stats">
            <div class="nav-icon">📊</div>
            <div class="nav-label">数据</div>
        </div>
        <div class="nav-item" data-page="mine">
            <div class="nav-icon">👤</div>
            <div class="nav-label">我的</div>
        </div>
    </div>
</div>

<!-- 新建/编辑书籍弹窗 -->
<div id="editBookModal" class="modal">
    <div class="modal-header">
        <h3 id="editBookModalTitle">编辑书籍</h3>
        <button onclick="closeEditBookModal()">✕</button>
    </div>
    <div class="modal-content">
        <div class="form-group">
            <label>📖 小说名字</label>
            <input type="text" id="editBookName" placeholder="请输入小说名称">
        </div>
        <div class="form-group">
            <label>✍️ 作者名字</label>
            <input type="text" id="editBookAuthor" placeholder="请输入作者名称">
        </div>
        <div class="form-group">
            <label>📝 小说简介</label>
            <textarea id="editBookDesc" rows="3" placeholder="请输入小说简介..."></textarea>
        </div>
        <div class="form-group">
            <label>🖼️ 小说封面</label>
            <input type="file" id="editBookCover" accept="image/*">
            <div id="editCoverPreview" class="cover-preview"></div>
        </div>
        <div class="form-group">
            <label>💰 千字稿费（元）</label>
            <input type="number" id="editBookPrice" placeholder="0" value="0">
        </div>
        <button class="btn-primary" onclick="saveBookEdit()">保存修改</button>
        <button class="btn-danger" onclick="deleteBookFromEdit()">删除书籍</button>
    </div>
</div>

<!-- 章节列表页面 -->
<div id="chapterPage" class="chapter-page">
    <div class="chapter-header">
    <button class="back-btn" onclick="closeChapterPage()">←</button>
    <h4 id="chapterPageTitle">加载中...</h4>
    <div style="display: flex; gap: 8px;">
        <button class="add-volume-btn-header" onclick="addNewVolume()">+ 分卷</button>
        <button class="add-chapter-btn" onclick="addNewChapter()">+ 章节</button>
