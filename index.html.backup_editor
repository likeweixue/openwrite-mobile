<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>写作帮手 - 移动版</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: #f5f5f5;
            height: 100vh;
            overflow: hidden;
        }
        
        /* 主容器 */
        .app-container {
            display: flex;
            flex-direction: column;
            height: 100vh;
            background: #f5f5f5;
        }
        
        /* 顶部导航 - 胶囊效果 */
.top-bar {
    background: transparent;
    padding: 12px 16px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
}

.top-bar h1 {
    display: none;
}

/* 新建书籍按钮 - 胶囊效果 */
.top-bar button {
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(20px);
    border: none;
    color: #1a1a1a;
    padding: 8px 20px;
    border-radius: 40px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.8);
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
}

.top-bar button:active {
    transform: scale(0.96);
    background: rgba(255,255,255,0.98);
}

.top-bar button::before {
    content: "+";
    font-size: 16px;
    font-weight: 600;
}
        
        /* 主内容区 */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
        }
        
        /* 书籍卡片 */
        .books-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 16px;
        }
        
        .book-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            position: relative;
        }
        
        .book-cover-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        
        .book-cover-placeholder {
            height: 180px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
        }
        
        .book-info {
            padding: 12px;
        }
        
        .book-title {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .book-stats {
            font-size: 11px;
            color: #888;
        }
        
        /* 书籍菜单按钮（三个点） */
        .book-menu-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(0,0,0,0.5);
            border: none;
            border-radius: 20px;
            width: 28px;
            height: 28px;
            font-size: 16px;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }
        
        /* 空状态 */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #999;
        }
        
        .empty-state .icon {
            font-size: 64px;
            margin-bottom: 16px;
        }
        
        /* 底部导航栏 - 胶囊等距圆角效果 */
.bottom-nav {
    display: flex;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(20px);
    border-top: none;
    padding: 6px;
    justify-content: space-around;
    border-radius: 40px;
    margin: 0 16px 16px 16px;
    gap: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08), inset 0 1px 0 rgba(255,255,255,0.8);
}

.nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px 0;
    border-radius: 32px;
    cursor: pointer;
    flex: 1;
    text-align: center;
    transition: all 0.25s ease;
    background: transparent;
    min-height: 52px;
}

.nav-item.active {
    background: linear-gradient(135deg, #1a1a1a, #2d2d2d);
    color: #fff;
    box-shadow: 0 6px 14px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.1);
}

.nav-item:active {
    transform: scale(0.96);
}

.nav-icon {
    font-size: 20px;
    transition: transform 0.2s;
}

.nav-item.active .nav-icon {
    transform: scale(1.02);
}

.nav-label {
    font-size: 10px;
    font-weight: 500;
    transition: all 0.2s;
}

.nav-item.active .nav-label {
    font-weight: 600;
    letter-spacing: 0.3px;
}
        
        /* 新建/编辑书籍弹窗 */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #fff;
            z-index: 1000;
            overflow-y: auto;
        }
        
        .modal.open {
            display: block;
        }
        
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            border-bottom: 1px solid #eee;
            background: #fff;
            position: sticky;
            top: 0;
        }
        
        .modal-header h3 {
            font-size: 18px;
        }
        
        .modal-header button {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            padding: 0 8px;
        }
        
        .modal-content {
            padding: 20px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            font-size: 14px;
        }
        
        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 12px;
            font-size: 16px;
            font-family: inherit;
            box-sizing: border-box;
        }
        
        .form-group textarea {
            resize: vertical;
        }
        
        .cover-preview {
            width: 100%;
            height: 150px;
            background: #f5f5f5;
            border-radius: 12px;
            background-size: cover;
            background-position: center;
            border: 1px solid #ddd;
            margin-top: 8px;
        }
        
        .btn-primary {
            width: 100%;
            padding: 14px;
            background: #9b784e;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            cursor: pointer;
        }
        
        .btn-danger {
            width: 100%;
            padding: 14px;
            background: #dc3545;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 12px;
        }
        
        /* 章节列表页面 */
        .chapter-page {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #f5f5f5;
            z-index: 200;
            flex-direction: column;
        }
        
        .chapter-page.open {
            display: flex;
        }
        
        .chapter-header {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid #eee;
            background: #fff;
            gap: 12px;
        }
        
        .back-btn {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            padding: 4px 8px;
        }
        
        .chapter-header h4 {
            flex: 1;
            font-size: 18px;
            font-weight: 600;
        }
        
        .add-chapter-btn {
            background: #9b784e;
            border: none;
            color: white;
            padding: 8px 16px;
            border-radius: 25px;
            font-size: 13px;
            cursor: pointer;
        }
        
        .chapter-list-container {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
        }
        
        .volume-group {
            background: #fff;
            border-radius: 16px;
            margin-bottom: 16px;
            overflow: hidden;
        }
        
        .volume-title {
            padding: 14px 16px;
            background: #f8f8f8;
            font-weight: 600;
            font-size: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #eee;
            cursor: move;
        }
        
        .volume-actions {
            display: flex;
            gap: 8px;
        }
        
        .volume-actions button {
            background: none;
            border: none;
            font-size: 16px;
            cursor: pointer;
            padding: 4px 8px;
        }
        
        .chapter-item {
            padding: 14px 16px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            background: #fff;
        }
        
        .chapter-item:active {
            background: #f5f5f5;
        }
        
        .chapter-item.dragging {
            opacity: 0.3;
            background: #e0e0e0;
        }
        
        .chapter-item.drag-over {
            border-top: 2px solid #007aff;
        }
        
        .chapter-name {
            flex: 1;
            font-size: 15px;
        }
        
        .chapter-actions {
            display: flex;
            gap: 12px;
        }
        
        .chapter-actions button {
            background: none;
            border: none;
            font-size: 16px;
            cursor: pointer;
            padding: 4px;
            color: #888;
        }
        
        /* 拖拽手柄 */
        .drag-handle {
            cursor: grab;
            margin-right: 12px;
            font-size: 16px;
            color: #ccc;
        }
        
        .drag-handle:active {
            cursor: grabbing;
        }
        
        /* 编辑器页面 */
        .editor-page {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #fff;
            z-index: 300;
            flex-direction: column;
        }
        
        .editor-page.open {
            display: flex;
        }
        
        .editor-header {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid #eee;
            background: #fff;
            gap: 12px;
        }
        
        .editor-content-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 16px;
        }
        
        .chapter-title-input {
            font-size: 20px;
            font-weight: 600;
            border: none;
            padding: 12px 0;
            outline: none;
            margin-bottom: 12px;
        }
        
        .chapter-editor {
            flex: 1;
            font-size: 16px;
            line-height: 1.6;
            border: none;
            outline: none;
            resize: none;
            font-family: inherit;
        }
        
        .word-count {
            text-align: right;
            font-size: 12px;
            color: #888;
            padding: 8px 0;
            border-top: 1px solid #eee;
            margin-top: 12px;
        }
        
        /* 弹窗确认 */
        .confirm-dialog {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            width: 280px;
            text-align: center;
            z-index: 2000;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            display: none;
        }
        
        .confirm-dialog.open {
            display: block;
        }
        
        .confirm-dialog p {
            margin-bottom: 20px;
        }
        
        .confirm-dialog button {
            padding: 8px 20px;
            margin: 0 8px;
            border: none;
            border-radius: 25px;
            cursor: pointer;
        }
        
        .confirm-dialog .confirm-yes {
            background: #dc3545;
            color: white;
        }
        
        .confirm-dialog .confirm-no {
            background: #eee;
        }
        
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1999;
            display: none;
        }
        
        .overlay.open {
            display: block;
        }
    </style>
</head>
<body>
<div class="app-container">
    <!-- 顶部栏 -->
    <div class="top-bar">
    <button id="newBookBtn">新建书籍</button>
</div>
    
    <!-- 主内容 -->
    <div class="main-content" id="mainContent">
        <div id="booksContainer"></div>
    </div>
    
    <!-- 底部导航 -->
    <div class="bottom-nav">
        <div class="nav-item active" data-page="books">
            <div class="nav-icon">📖</div>
            <div class="nav-label">书籍</div>
        </div>
        <div class="nav-item" data-page="stats">
            <div class="nav-icon">📊</div>
            <div class="nav-label">数据</div>
        </div>
        <div class="nav-item" data-page="mine">
            <div class="nav-icon">👤</div>
            <div class="nav-label">我的</div>
        </div>
    </div>
</div>

<!-- 新建/编辑书籍弹窗 -->
<div id="editBookModal" class="modal">
    <div class="modal-header">
        <h3 id="editBookModalTitle">编辑书籍</h3>
        <button onclick="closeEditBookModal()">✕</button>
    </div>
    <div class="modal-content">
        <div class="form-group">
            <label>📖 小说名字</label>
            <input type="text" id="editBookName" placeholder="请输入小说名称">
        </div>
        <div class="form-group">
            <label>✍️ 作者名字</label>
            <input type="text" id="editBookAuthor" placeholder="请输入作者名称">
        </div>
        <div class="form-group">
            <label>📝 小说简介</label>
            <textarea id="editBookDesc" rows="3" placeholder="请输入小说简介..."></textarea>
        </div>
        <div class="form-group">
            <label>🖼️ 小说封面</label>
            <input type="file" id="editBookCover" accept="image/*">
            <div id="editCoverPreview" class="cover-preview"></div>
        </div>
        <div class="form-group">
            <label>💰 千字稿费（元）</label>
            <input type="number" id="editBookPrice" placeholder="0" value="0">
        </div>
        <button class="btn-primary" onclick="saveBookEdit()">保存修改</button>
        <button class="btn-danger" onclick="deleteBookFromEdit()">删除书籍</button>
    </div>
</div>

<!-- 章节列表页面 -->
<div id="chapterPage" class="chapter-page">
    <div class="chapter-header">
        <button class="back-btn" onclick="closeChapterPage()">←</button>
        <h4 id="chapterPageTitle">加载中...</h4>
        <button class="add-chapter-btn" onclick="addNewChapter()">+ 章节</button>
    </div>
    <div class="chapter-list-container" id="chapterListContainer"></div>
</div>

<!-- 编辑器页面 -->
<div id="editorPage" class="editor-page">
    <div class="editor-header">
        <button class="back-btn" onclick="closeEditor()">←</button>
        <h4 id="editorTitle">编辑章节</h4>
    </div>
    <div class="editor-content-area">
        <input type="text" id="chapterTitle" class="chapter-title-input" placeholder="章节标题">
        <textarea id="chapterContent" class="chapter-editor" placeholder="开始写作..."></textarea>
        <div class="word-count">0 字</div>
    </div>
</div>

<!-- 确认弹窗 -->
<div class="overlay" id="overlay"></div>
<div class="confirm-dialog" id="confirmDialog">
    <p id="confirmMessage">确定删除吗？</p>
    <button class="confirm-no" onclick="hideConfirm()">取消</button>
    <button class="confirm-yes" onclick="confirmAction()">确定</button>
</div>

<script>
// ========== 数据模型 ==========
let books = [];
let currentBookId = null;
let currentVolumeId = null;
let currentChapterId = null;
let currentEditBookId = null;
let pendingDelete = null;

// 章节类
class Chapter {
    constructor(id, title, content) {
        this.id = id;
        this.title = title;
        this.content = content;
        this.createdTime = new Date().toISOString();
        this.updatedTime = new Date().toISOString();
    }
}

// 分卷类
class Volume {
    constructor(id, name, chapters) {
        this.id = id;
        this.name = name;
        this.chapters = chapters || [];
    }
}

// 书籍类
class Book {
    constructor(id, title, volumes) {
        this.id = id;
        this.title = title;
        this.volumes = volumes || [];
        this.createdAt = new Date().toISOString();
    }
}

// 加载数据
function loadData() {
    let saved = localStorage.getItem('mobile_writing_books');
    if (saved) {
        try {
            books = JSON.parse(saved);
        } catch(e) {}
    }
    if (!books || books.length === 0) {
        let sampleChapter = new Chapter(Date.now(), '第一章', '这里是一个开始...');
        let sampleVolume = new Volume(Date.now(), '第一卷', [sampleChapter]);
        let sampleBook = new Book(Date.now(), '斗破苍穹', [sampleVolume]);
        sampleBook.author = '天蚕土豆';
        sampleBook.desc = '三十年河东三十年河西，莫欺少年穷！';
        sampleBook.price = 15;
        books = [sampleBook];
        saveData();
    }
    renderBooks();
}

function saveData() {
    localStorage.setItem('mobile_writing_books', JSON.stringify(books));
}

// 渲染书籍列表
function renderBooks() {
    let container = document.getElementById('booksContainer');
    if (!container) return;
    
    if (books.length === 0) {
        container.innerHTML = '<div class="empty-state"><div class="icon">📚</div><div>暂无书籍，点击右上角"新建书籍"开始创作</div></div>';
        return;
    }
    
    let html = '<div class="books-grid">';
    for (let i = 0; i < books.length; i++) {
        let book = books[i];
        let totalChapters = 0;
        if (book.volumes) {
            for (let v of book.volumes) {
                if (v.chapters) totalChapters += v.chapters.length;
            }
        }
        
        // 封面显示逻辑
        let coverHtml = '';
        if (book.cover) {
            coverHtml = `<img src="${book.cover}" class="book-cover-img" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">`;
            coverHtml += `<div class="book-cover-placeholder" style="display:none;">📖</div>`;
        } else {
            coverHtml = `<div class="book-cover-placeholder">📖</div>`;
        }
        
        html += `
            <div class="book-card">
                <button class="book-menu-btn" onclick="event.stopPropagation(); openBookEditMenu(${book.id})">⋯</button>
                <div onclick="openChapterList(${book.id})">
                    ${coverHtml}
                    <div class="book-info">
                        <div class="book-title">${escapeHtml(book.title)}</div>
                        <div class="book-stats">${book.volumes ? book.volumes.length : 0}卷 · ${totalChapters}章</div>
                    </div>
                </div>
            </div>
        `;
    }
    html += '</div>';
    container.innerHTML = html;
}

// 打开书籍编辑菜单
function openBookEditMenu(bookId) {
    currentEditBookId = bookId;
    let book = books.find(b => b.id == bookId);
    if (!book) return;
    
    document.getElementById('editBookModalTitle').innerText = '编辑书籍';
    document.getElementById('editBookName').value = book.title || '';
    document.getElementById('editBookAuthor').value = book.author || '';
    document.getElementById('editBookDesc').value = book.desc || '';
    document.getElementById('editBookPrice').value = book.price || 0;
    document.getElementById('editCoverPreview').style.backgroundImage = book.cover ? 'url(' + book.cover + ')' : '';
    document.getElementById('editCoverPreview').style.backgroundSize = 'cover';
    
    document.getElementById('editBookModal').classList.add('open');
}

// 关闭编辑弹窗
function closeEditBookModal() {
    document.getElementById('editBookModal').classList.remove('open');
    currentEditBookId = null;
    document.getElementById('editBookName').value = '';
    document.getElementById('editBookAuthor').value = '';
    document.getElementById('editBookDesc').value = '';
    document.getElementById('editBookPrice').value = '0';
    document.getElementById('editCoverPreview').style.backgroundImage = '';
}

// 保存书籍编辑
function saveBookEdit() {
    if (!currentEditBookId) return;
    let book = books.find(b => b.id == currentEditBookId);
    if (!book) return;
    
    let newName = document.getElementById('editBookName').value.trim();
    if (!newName) {
        alert('请输入书籍名称');
        return;
    }
    
    book.title = newName;
    book.author = document.getElementById('editBookAuthor').value;
    book.desc = document.getElementById('editBookDesc').value;
    book.price = document.getElementById('editBookPrice').value;
    
    let coverFile = document.getElementById('editBookCover').files[0];
    if (coverFile) {
        let reader = new FileReader();
        reader.onload = function(ev) {
            book.cover = ev.target.result;
            saveData();
            renderBooks();
            closeEditBookModal();
            alert('保存成功');
        };
        reader.readAsDataURL(coverFile);
    } else {
        saveData();
        renderBooks();
        closeEditBookModal();
        alert('保存成功');
    }
}

// 删除书籍
function deleteBookFromEdit() {
    showConfirm('确定删除这本书吗？所有章节也会被删除！', function() {
        books = books.filter(b => b.id != currentEditBookId);
        saveData();
        renderBooks();
        closeEditBookModal();
        alert('书籍已删除');
    });
}

// 打开章节列表
function openChapterList(bookId) {
    currentBookId = bookId;
    let book = books.find(b => b.id == bookId);
    if (!book) return;
    
    document.getElementById('chapterPageTitle').innerText = book.title;
    renderChapterList();
    document.getElementById('chapterPage').classList.add('open');
}

// 渲染章节列表
function renderChapterList() {
    let book = books.find(b => b.id == currentBookId);
    if (!book) return;
    
    let container = document.getElementById('chapterListContainer');
    let html = '';
    
    for (let vi = 0; vi < book.volumes.length; vi++) {
        let vol = book.volumes[vi];
        html += `
            <div class="volume-group" data-volume-id="${vol.id}" data-volume-index="${vi}">
                <div class="volume-title" draggable="true">
                    <span>📂 ${escapeHtml(vol.name)}</span>
                    <div class="volume-actions">
                        <button onclick="event.stopPropagation(); addChapterToVolume(${vol.id})" title="添加章节">+</button>
                        <button onclick="event.stopPropagation(); renameVolume(${vol.id}, '${escapeHtml(vol.name)}')" title="重命名">✏️</button>
                        <button onclick="event.stopPropagation(); deleteVolume(${vol.id})" title="删除分卷">🗑</button>
                    </div>
                </div>
                <div class="chapters-list" data-volume-id="${vol.id}">
        `;
        
        for (let ci = 0; ci < vol.chapters.length; ci++) {
            let ch = vol.chapters[ci];
            html += `
                <div class="chapter-item" data-chapter-id="${ch.id}" data-volume-id="${vol.id}" data-chapter-index="${ci}" draggable="true">
                    <div style="display: flex; align-items: center; flex: 1;">
                        <span class="drag-handle">⋮⋮</span>
                        <span class="chapter-name" onclick="event.stopPropagation(); openEditor(${vol.id}, ${ch.id})">📄 ${escapeHtml(ch.title)}</span>
                    </div>
                    <div class="chapter-actions">
                        <button onclick="event.stopPropagation(); renameChapter(${vol.id}, ${ch.id}, '${escapeHtml(ch.title)}')" title="重命名">✏️</button>
                        <button onclick="event.stopPropagation(); deleteChapter(${vol.id}, ${ch.id})" title="删除">🗑</button>
                    </div>
                </div>
            `;
        }
        html += `</div></div>`;
    }
    
    // 添加新分卷按钮
    html += `
        <div style="text-align: center; padding: 8px 0;">
    <button class="add-volume-btn" onclick="addNewVolume()">+ 添加新分卷</button>
</div>
    `;
    
    container.innerHTML = html;
    initDragAndDrop();
}

// 初始化拖拽排序
function initDragAndDrop() {
    let dragSource = null;
    let dragSourceVolumeId = null;
    let dragSourceIndex = null;
    
    let chapters = document.querySelectorAll('.chapter-item');
    
    chapters.forEach(chapter => {
        chapter.addEventListener('dragstart', function(e) {
            dragSource = this;
            dragSourceVolumeId = parseInt(this.getAttribute('data-volume-id'));
            dragSourceIndex = parseInt(this.getAttribute('data-chapter-index'));
            this.classList.add('dragging');
            e.dataTransfer.setData('text/plain', '');
            e.dataTransfer.effectAllowed = 'move';
        });
        
        chapter.addEventListener('dragend', function(e) {
            this.classList.remove('dragging');
            dragSource = null;
            dragSourceVolumeId = null;
            dragSourceIndex = null;
            document.querySelectorAll('.chapter-item').forEach(c => {
                c.classList.remove('drag-over');
            });
        });
        
        chapter.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            if (dragSource && dragSource !== this) {
                this.classList.add('drag-over');
            }
        });
        
        chapter.addEventListener('dragleave', function(e) {
            this.classList.remove('drag-over');
        });
        
        chapter.addEventListener('drop', function(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
            
            if (!dragSource || dragSource === this) return;
            
            let targetVolumeId = parseInt(this.getAttribute('data-volume-id'));
            let targetIndex = parseInt(this.getAttribute('data-chapter-index'));
            
            let book = books.find(b => b.id == currentBookId);
            
            let sourceVol = book.volumes.find(v => v.id == dragSourceVolumeId);
            let targetVol = book.volumes.find(v => v.id == targetVolumeId);
            
            if (!sourceVol || !targetVol) return;
            
            let movedChapter = sourceVol.chapters[dragSourceIndex];
            sourceVol.chapters.splice(dragSourceIndex, 1);
            
            let targetIndexAdjusted = targetIndex;
            if (dragSourceVolumeId === targetVolumeId && dragSourceIndex < targetIndex) {
                targetIndexAdjusted--;
            }
            targetVol.chapters.splice(targetIndexAdjusted, 0, movedChapter);
            
            saveData();
            renderChapterList();
        });
    });
    
    let volumes = document.querySelectorAll('.volume-group');
    let dragVolumeSource = null;
    let dragVolumeIndex = null;
    
    volumes.forEach(vol => {
        let titleDiv = vol.querySelector('.volume-title');
        if (titleDiv) {
            titleDiv.addEventListener('dragstart', function(e) {
                dragVolumeSource = vol;
                dragVolumeIndex = parseInt(vol.getAttribute('data-volume-index'));
                this.classList.add('dragging');
                e.dataTransfer.setData('text/plain', '');
                e.dataTransfer.effectAllowed = 'move';
            });
            
            titleDiv.addEventListener('dragend', function(e) {
                this.classList.remove('dragging');
                dragVolumeSource = null;
                dragVolumeIndex = null;
                document.querySelectorAll('.volume-group').forEach(v => {
                    v.classList.remove('drag-over');
                });
            });
            
            titleDiv.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                if (dragVolumeSource && dragVolumeSource !== vol) {
                    vol.classList.add('drag-over');
                }
            });
            
            titleDiv.addEventListener('dragleave', function(e) {
                vol.classList.remove('drag-over');
            });
            
            titleDiv.addEventListener('drop', function(e) {
                e.preventDefault();
                vol.classList.remove('drag-over');
                
                if (!dragVolumeSource || dragVolumeSource === vol) return;
                
                let targetIndex = parseInt(vol.getAttribute('data-volume-index'));
                let book = books.find(b => b.id == currentBookId);
                
                let movedVolume = book.volumes[dragVolumeIndex];
                book.volumes.splice(dragVolumeIndex, 1);
                
                let adjustedTarget = targetIndex;
                if (dragVolumeIndex < targetIndex) {
                    adjustedTarget--;
                }
                book.volumes.splice(adjustedTarget, 0, movedVolume);
                
                saveData();
                renderChapterList();
            });
        }
    });
}

// 添加新分卷
function addNewVolume() {
    let name = prompt('请输入分卷名称', '新分卷');
    if (!name) return;
    
    let book = books.find(b => b.id == currentBookId);
    let newVolume = new Volume(Date.now(), name, []);
    book.volumes.push(newVolume);
    saveData();
    renderChapterList();
}

// 添加章节到分卷（自动生成序号）
function addChapterToVolume(volId) {
    let book = books.find(b => b.id == currentBookId);
    let vol = book.volumes.find(v => v.id == volId);
    
    // 获取当前章节数量，自动生成序号
    let chapterCount = vol.chapters.length;
    let chineseNum = ['零', '一', '二', '三', '四', '五', '六', '七', '八', '九', '十'];
    let newNumber = chapterCount + 1;
    let chapterTitle = '';
    
    if (newNumber <= 10) {
        chapterTitle = '第' + chineseNum[newNumber] + '章';
    } else {
        chapterTitle = '第' + newNumber + '章';
    }
    
    let newChapter = new Chapter(Date.now(), chapterTitle, '');
    vol.chapters.push(newChapter);
    saveData();
    renderChapterList();
}

// 添加新章节（顶部按钮）
function addNewChapter() {
    let book = books.find(b => b.id == currentBookId);
    if (!book.volumes.length) {
        addNewVolume();
        return;
    }
    let vol = book.volumes[0];
    addChapterToVolume(vol.id);
}

// 重命名分卷
function renameVolume(volId, oldName) {
    let newName = prompt('请输入新名称', oldName);
    if (!newName) return;
    
    let book = books.find(b => b.id == currentBookId);
    let vol = book.volumes.find(v => v.id == volId);
    vol.name = newName;
    saveData();
    renderChapterList();
}

// 删除分卷
function deleteVolume(volId) {
    showConfirm('确定删除这个分卷吗？分卷内的章节也会被删除！', function() {
        let book = books.find(b => b.id == currentBookId);
        book.volumes = book.volumes.filter(v => v.id != volId);
        if (book.volumes.length === 0) {
            let newVolume = new Volume(Date.now(), '第一卷', []);
            book.volumes.push(newVolume);
        }
        saveData();
        renderChapterList();
    });
}

// 重命名章节
function renameChapter(volId, chId, oldName) {
    let newName = prompt('请输入新名称', oldName);
    if (!newName) return;
    
    let book = books.find(b => b.id == currentBookId);
    let vol = book.volumes.find(v => v.id == volId);
    let ch = vol.chapters.find(c => c.id == chId);
    ch.title = newName;
    saveData();
    renderChapterList();
}

// 删除章节
function deleteChapter(volId, chId) {
    showConfirm('确定删除这个章节吗？', function() {
        let book = books.find(b => b.id == currentBookId);
        let vol = book.volumes.find(v => v.id == volId);
        vol.chapters = vol.chapters.filter(c => c.id != chId);
        if (vol.chapters.length === 0) {
            let newChapter = new Chapter(Date.now(), '第一章', '');
            vol.chapters.push(newChapter);
        }
        saveData();
        renderChapterList();
    });
}

// 打开编辑器
function openEditor(volId, chId) {
    currentVolumeId = volId;
    currentChapterId = chId;
    
    let book = books.find(b => b.id == currentBookId);
    let vol = book.volumes.find(v => v.id == volId);
    let ch = vol.chapters.find(c => c.id == chId);
    
    document.getElementById('editorTitle').innerText = ch.title;
    document.getElementById('chapterTitle').value = ch.title;
    document.getElementById('chapterContent').value = ch.content.replace(/<[^>]*>/g, '');
    updateWordCount();
    
    document.getElementById('editorPage').classList.add('open');
}

// 关闭章节列表页
function closeChapterPage() {
    document.getElementById('chapterPage').classList.remove('open');
    currentBookId = null;
    renderBooks();
}

// 关闭编辑器
function closeEditor() {
    saveCurrentChapter();
    document.getElementById('editorPage').classList.remove('open');
    renderChapterList();
}

// 更新字数
function updateWordCount() {
    let content = document.getElementById('chapterContent').value;
    document.querySelector('#editorPage .word-count').innerText = content.length + ' 字';
}

// 保存章节
function saveCurrentChapter() {
    if (!currentBookId || !currentVolumeId || !currentChapterId) return;
    
    let book = books.find(b => b.id == currentBookId);
    let vol = book.volumes.find(v => v.id == currentVolumeId);
    let ch = vol.chapters.find(c => c.id == currentChapterId);
    
    if (ch) {
        ch.title = document.getElementById('chapterTitle').value;
        ch.content = document.getElementById('chapterContent').value.replace(/\n/g, '<br>');
        ch.updatedTime = new Date().toISOString();
        saveData();
    }
}

// 新建书籍
function openNewBookModal() {
    currentEditBookId = null;
    document.getElementById('editBookModalTitle').innerText = '新建书籍';
    document.getElementById('editBookName').value = '';
    document.getElementById('editBookAuthor').value = '';
    document.getElementById('editBookDesc').value = '';
    document.getElementById('editBookPrice').value = '0';
    document.getElementById('editCoverPreview').style.backgroundImage = '';
    document.getElementById('editBookModal').classList.add('open');
}

function closeNewBookModal() {
    closeEditBookModal();
}

function createNewBook() {
    let name = document.getElementById('editBookName').value.trim();
    if (!name) {
        alert('请输入小说名称');
        return;
    }
    let author = document.getElementById('editBookAuthor').value;
    let desc = document.getElementById('editBookDesc').value;
    let price = document.getElementById('editBookPrice').value;
    let coverFile = document.getElementById('editBookCover').files[0];
    
    let newChapter = new Chapter(Date.now(), '第一章', '');
    let newVolume = new Volume(Date.now(), '第一卷', [newChapter]);
    let newBook = new Book(Date.now(), name, [newVolume]);
    newBook.author = author;
    newBook.desc = desc;
    newBook.price = price;
    
    if (coverFile) {
        let reader = new FileReader();
        reader.onload = function(ev) {
            newBook.cover = ev.target.result;
            books.push(newBook);
            saveData();
            renderBooks();
            closeEditBookModal();
            alert('书籍《' + name + '》创建成功');
        };
        reader.readAsDataURL(coverFile);
    } else {
        books.push(newBook);
        saveData();
        renderBooks();
        closeEditBookModal();
        alert('书籍《' + name + '》创建成功');
    }
}

// 封面预览
document.getElementById('editBookCover').onchange = function(e) {
    let file = e.target.files[0];
    if (file) {
        let reader = new FileReader();
        reader.onload = function(ev) {
            document.getElementById('editCoverPreview').style.backgroundImage = 'url(' + ev.target.result + ')';
            document.getElementById('editCoverPreview').style.backgroundSize = 'cover';
        };
        reader.readAsDataURL(file);
    }
};

// 自动保存
let autoSaveTimer;
document.getElementById('chapterTitle').oninput = function() {
    clearTimeout(autoSaveTimer);
    autoSaveTimer = setTimeout(saveCurrentChapter, 500);
};
document.getElementById('chapterContent').oninput = function() {
    updateWordCount();
    clearTimeout(autoSaveTimer);
    autoSaveTimer = setTimeout(saveCurrentChapter, 500);
};

// 确认弹窗
function showConfirm(message, onConfirm) {
    pendingDelete = onConfirm;
    document.getElementById('confirmMessage').innerText = message;
    document.getElementById('overlay').classList.add('open');
    document.getElementById('confirmDialog').classList.add('open');
}

function hideConfirm() {
    pendingDelete = null;
    document.getElementById('overlay').classList.remove('open');
    document.getElementById('confirmDialog').classList.remove('open');
}

function confirmAction() {
    if (pendingDelete) {
        pendingDelete();
        pendingDelete = null;
    }
    hideConfirm();
}

// 底部导航
document.querySelectorAll('.nav-item').forEach(item => {
    item.onclick = function() {
        let page = this.getAttribute('data-page');
        document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
        this.classList.add('active');
        
        if (page === 'books') {
            renderBooks();
        } else if (page === 'stats') {
            let totalWords = 0;
            for (let book of books) {
                for (let v of book.volumes) {
                    for (let ch of v.chapters) {
                        totalWords += (ch.content || '').replace(/<[^>]*>/g, '').length;
                    }
                }
            }
            document.getElementById('booksContainer').innerHTML = `
                <div class="empty-state">
                    <div class="icon">📊</div>
                    <div style="font-weight:600; margin-bottom:8px;">数据统计</div>
                    <div style="font-size:14px; color:#666;">总字数：${totalWords} 字</div>
                    <div style="font-size:14px; color:#666;">书籍数量：${books.length} 本</div>
                </div>
            `;
        } else if (page === 'mine') {
            let totalWords = 0;
            for (let book of books) {
                for (let v of book.volumes) {
                    for (let ch of v.chapters) {
                        totalWords += (ch.content || '').replace(/<[^>]*>/g, '').length;
                    }
                }
            }
            document.getElementById('booksContainer').innerHTML = `
                <div class="empty-state">
                    <div class="icon">👤</div>
                    <div style="font-weight:600; margin-bottom:8px;">我的</div>
                    <div style="font-size:14px; color:#666;">总字数：${totalWords} 字</div>
                    <div style="font-size:14px; color:#666;">书籍数量：${books.length} 本</div>
                    <div style="margin-top:20px; font-size:12px; color:#888;">写作帮手 OpenWrite</div>
                    <div style="font-size:12px; color:#888;">免费 · 开源 · 自由写作</div>
                </div>
            `;
        }
    };
});

// 工具函数
function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

// 绑定新建书籍按钮
document.getElementById('newBookBtn').onclick = openNewBookModal;

// 初始化
loadData();
</script>
